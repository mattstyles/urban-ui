{
  "name": "@urban-ui/theme",
  "version": "0.0.0",
  "description": "Design tokens for Urban UI — StyleX defineVars groups and their documentation.",
  "license": "MIT",
  "author": "Matt Styles",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattstyles/urban-ui.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist",
    "global.css",
    "philosophy.md",
    "urban-manifest.json"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.stylex.*"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./color.stylex": {
      "source": "./src/color.stylex.ts",
      "types": "./dist/color.stylex.d.ts",
      "default": "./dist/color.stylex.js"
    },
    "./text.stylex": {
      "source": "./src/text.stylex.ts",
      "types": "./dist/text.stylex.d.ts",
      "default": "./dist/text.stylex.js"
    },
    "./editorial.stylex": {
      "source": "./src/editorial.stylex.ts",
      "types": "./dist/editorial.stylex.d.ts",
      "default": "./dist/editorial.stylex.js"
    },
    "./space.stylex": {
      "source": "./src/space.stylex.ts",
      "types": "./dist/space.stylex.d.ts",
      "default": "./dist/space.stylex.js"
    },
    "./shape.stylex": {
      "source": "./src/shape.stylex.ts",
      "types": "./dist/shape.stylex.d.ts",
      "default": "./dist/shape.stylex.js"
    },
    "./tokens.stylex": {
      "source": "./src/tokens.stylex.ts",
      "types": "./dist/tokens.stylex.d.ts",
      "default": "./dist/tokens.stylex.js"
    },
    "./global.css": "./global.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "check-package": "publint && attw --pack . --profile esm-only --exclude-entrypoints ./global.css"
  },
  "devDependencies": {
    "@stylexjs/stylex": "catalog:",
    "@urban-ui/config": "workspace:*"
  },
  "peerDependencies": {
    "@stylexjs/stylex": "catalog:"
  },
  "urban": {
    "manifest": "./urban-manifest.json"
  }
}
