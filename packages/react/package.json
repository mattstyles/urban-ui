{
  "name": "@urban-ui/react",
  "version": "0.0.0",
  "description": "Urban UI component library — react-aria-components styled with StyleX.",
  "license": "MIT",
  "author": "Matt Styles",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattstyles/urban-ui.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "src/**/*.md",
    "src/**/examples/*",
    "urban-manifest.json"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.stylex.*"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./button": {
      "source": "./src/button/index.ts",
      "types": "./dist/button/index.d.ts",
      "default": "./dist/button/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit -p tsconfig.check.json",
    "lint": "oxlint src",
    "check-package": "publint && attw --pack . --profile esm-only"
  },
  "devDependencies": {
    "@react-aria/test-utils": "1.0.0-rc.0",
    "@stylexjs/stylex": "catalog:",
    "@stylexjs/unplugin": "0.19.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.5.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@urban-ui/config": "workspace:*",
    "@urban-ui/theme": "workspace:*",
    "jsdom": "29.1.1",
    "react": "catalog:",
    "react-aria-components": "catalog:",
    "react-dom": "catalog:",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "@stylexjs/stylex": "catalog:",
    "@urban-ui/theme": "workspace:*",
    "react": "catalog:",
    "react-aria-components": "catalog:"
  },
  "urban": {
    "manifest": "./urban-manifest.json"
  }
}
